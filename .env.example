DATABRICKS_HOST=<your-databrick-host>
DATABRICKS_TOKEN=your-databricks-personal-access-token-here

# Models (optional — these are the defaults if unset). Must be chat endpoints on the AI Gateway.
AGENT_MODEL=databricks-gpt-5-4
JUDGE_MODEL=databricks-claude-opus-4-6

# Unity Catalog location for all demo assets — change these to run in your own workspace.
# You need CREATE privileges on the catalog (00_production_traffic_and_monitoring creates the schema + tables).
CATALOG=your_catalog
SCHEMA=case_ticket

# MLflow experiment path (must be a workspace path you can write to).
MLFLOW_EXPERIMENT_NAME=/Shared/eval_flywheel_support_triage

# SQL warehouse ID for production scorer monitoring (optional). If set, 00_production_traffic_and_monitoring registers
# the 5 scorers and starts monitoring on sampled prod traces. Leave empty to skip.
# Requires CAN USE on the warehouse and CAN EDIT on the experiment.
MONITORING_WAREHOUSE_ID=
